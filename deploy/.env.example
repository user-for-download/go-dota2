# =============================================================================
# go-dota2 — Environment Configuration
# =============================================================================
# Copy this file to `.env` and adjust as needed.
# All durations use Go's time.ParseDuration syntax: "500ms", "5s", "10m", "24h".
# All booleans accept: 1/0, true/false, t/f, yes/no (case-insensitive).
# CSV values are comma-separated; whitespace around commas is trimmed.
# =============================================================================

# -----------------------------------------------------------------------------
# Application (informational only – not used by code)
# -----------------------------------------------------------------------------
APP_ENV=dev                       # dev | staging | prod
LOG_LEVEL=info                    # debug | info | warn | error

# -----------------------------------------------------------------------------
# Redis (required by every service)
# -----------------------------------------------------------------------------
REDIS_ADDRS=redis:6379            # CSV, e.g. "redis-a:6379,redis-b:6379"
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=100               # 0 → default (10 * NumCPU)
REDIS_MIN_IDLE_CONNS=10
REDIS_MAX_ACTIVE_CONNS=0
REDIS_CONN_MAX_LIFETIME=30m
REDIS_CONN_MAX_IDLE_TIME=10m
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_READ_ONLY=false             # true + ≥2 addresses → use second for reads

# Compose‑only (not read by Go code)
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
# Primary services (fetcher, parser, enricher) use POSTGRES_DSN.
POSTGRES_DSN=postgres://dota2:dota2@postgres:5432/dota2?sslmode=disable

POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m
POSTGRES_CONN_MAX_IDLE_TIME=10m

# -----------------------------------------------------------------------------
# Proxy Pool (Redis‑backed)
# -----------------------------------------------------------------------------
PROXY_HOLD=30s                    # lease TTL for a proxy
PROXY_MIN_POOL_SIZE=0             # below this → force refresh; 0 = disable
PROXY_KEY_PREFIX=dota2:proxy
PROXY_ACQUIRE_LIMIT=0             # max candidates considered; 0 → 500
PROXY_RATE_LIMIT_PER_SEC=0        # 0 disables rate limiting
PROXY_RATE_LIMIT_BURST=0
PROXY_RATE_LIMIT_WINDOW=1s
PROXY_RANKING_INITIAL=100
PROXY_RANKING_SUCCESS=1
PROXY_RANKING_FAILURE=5            # penalty (positive value subtracted from score on failure)
PROXY_MAX_FAILURES=5

# -----------------------------------------------------------------------------
# Proxy Loader (cmd/proxyloader)
# -----------------------------------------------------------------------------
PROXY_SEED_FILE=proxy.txt
PROXY_REMOTE_URL=                 # optional HTTP source of proxy list
PROXY_CANARY_URL=https://api.ipify.org
PROXY_VALIDATE_TIMEOUT=10s
PROXY_VALIDATE_PARALLEL=50
PROXY_VALIDATE_CHUNK_SIZE=100
PROXY_VALIDATE_MIN_PUBLISH=1      # minimum healthy proxies to publish a chunk
PROXY_REFRESH_INTERVAL=0          # 0 = one‑shot mode
PROXY_FORCE_REFRESH_INTERVAL=1h
# -----------------------------------------------------------------------------
# Discovery (cmd/discoverer)
# -----------------------------------------------------------------------------
DISCOVERY_UPSTREAM_URL=           # REQUIRED – e.g.https://api.opendota.com/api/explorer
DISCOVERY_QUERIES_DIR=/queries/matches
DISCOVERY_DEFAULT_KEY=default
DISCOVERY_WAIT_TIMEOUT=5m
DISCOVERY_HTTP_TIMEOUT=30s
DISCOVERY_INTERVAL=24h
DISCOVERY_RUN_AT_START=true
DISCOVERY_MAX_RETRIES=8
DISCOVERY_RETRY_BACKOFF=500ms
DISCOVERY_MIN_PROXY_POOL_SIZE=1

# League discovery (optional)
DISCOVERY_LEAGUE_QUERIES_DIR=/queries/leagues
DISCOVERY_LEAGUE_INTERVAL=6h

# Team discovery (optional)
DISCOVERY_TEAM_QUERIES_DIR=/queries/teams
DISCOVERY_TEAM_INTERVAL=6h

# Pro player discovery (optional)
DISCOVERY_PRO_PLAYER_URL=https://api.opendota.com/api/proPlayers
DISCOVERY_PRO_PLAYER_INTERVAL=6h

# -----------------------------------------------------------------------------
# Fetcher (cmd/fetcher)
# -----------------------------------------------------------------------------
FETCHER_UPSTREAM_URL=             # REQUIRED – e.g. https://api.opendota.com/api/matches/%d
FETCHER_BATCH=10
FETCHER_BLOCK=2s
FETCHER_HTTP_TIMEOUT=15s
FETCHER_PAYLOAD_TTL=1h
FETCHER_WAIT_TIMEOUT=5m
FETCHER_MAX_PROXY_RETRIES=5
FETCHER_PROXY_BACKOFF=250ms
FETCHER_ALLOW_DIRECT=false

# -----------------------------------------------------------------------------
# Parser (cmd/parser)
# -----------------------------------------------------------------------------
PARSER_BATCH=10
PARSER_BLOCK=2s

# -----------------------------------------------------------------------------
# Queues (Redis Streams)
# -----------------------------------------------------------------------------
QUEUE_GROUP=workers
QUEUE_CONSUMER=                   # empty → defaults to container hostname
QUEUE_MAX_LEN=100000
QUEUE_DELETE_ON_ACK=false
QUEUE_MAX_RETRIES=3
QUEUE_MAX_BACKOFF=30s

QUEUE_FETCH_STREAM=dota2:fetch
QUEUE_FETCH_DLQ_STREAM=dota2:fetch:dlq
QUEUE_PARSE_STREAM=dota2:parse
QUEUE_PARSE_DLQ_STREAM=dota2:parse:dlq

# -----------------------------------------------------------------------------
# Payload Store (Redis)
# -----------------------------------------------------------------------------
PAYLOAD_KEY_PREFIX=dota2:payload
PAYLOAD_DEFAULT_TTL=24h

# -----------------------------------------------------------------------------
# Deduplication (Redis)
# -----------------------------------------------------------------------------
DEDUP_KEY_PREFIX=dota2:seen
DEDUP_TTL=24h                     # 0 means use a SET (no expiry)

# -----------------------------------------------------------------------------
# Enricher (cmd/enricher)
# -----------------------------------------------------------------------------
ENRICH_BOOTSTRAP_PREFIX=dota2:enrich
ENRICH_BOOTSTRAP_TTL=720h         # 30 days
ENRICH_DOTACONSTANTS_BASE_URL=https://raw.githubusercontent.com/odota/dotaconstants/master/build
ENRICH_HTTP_TIMEOUT=30s
ENRICH_INTERVAL=24h
ENRICH_RUN_AT_START=true
ENRICH_ALLOW_DIRECT=false
ENRICH_WAIT_TIMEOUT=5m
ENRICH_MAX_PROXY_RETRIES=5
ENRICH_PROXY_BACKOFF=500ms

# Force reload of already bootstrapped sources
ENRICH_FORCE_BOOTSTRAP=false

# Local bootstrap: path to JSON files for instant first-run (e.g., /dotaconstants/build)
ENRICH_LOCAL_DIR=

# -----------------------------------------------------------------------------
# OpenTelemetry (Tracing + Metrics)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4318   # docker: jaeger:4318, local: localhost:4318
OTEL_SAMPLE_RATE=1.0

# -----------------------------------------------------------------------------
# Migrator (cmd/migrator)
# -----------------------------------------------------------------------------
MIGRATOR_DSN=postgres://dota2:dota2@postgres:5432/dota2?sslmode=disable
MIGRATOR_MIGRATIONS_DIR=/migrations

# -----------------------------------------------------------------------------
# Build / Deploy (Makefile + compose, not read by Go)
# -----------------------------------------------------------------------------
TAG=latest
BUILDX_BAKE_ENTITLEMENTS_FS=0
PROJECT_NAME=go-dota2

