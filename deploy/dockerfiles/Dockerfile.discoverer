# syntax=docker/dockerfile:1.7
FROM go-dota2-base-local AS builder

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata && \
    addgroup -S app && adduser -S -G app app
COPY --from=builder /out/discoverer /app/discoverer
COPY deploy/queries /queries
USER app
WORKDIR /app
ENV DISCOVERY_QUERIES_DIR=/queries
ENTRYPOINT ["/app/discoverer"]